#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/fast-npm-meta@1.4.2/node_modules/fast-npm-meta/node_modules:/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/fast-npm-meta@1.4.2/node_modules:/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/fast-npm-meta@1.4.2/node_modules/fast-npm-meta/node_modules:/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/fast-npm-meta@1.4.2/node_modules:/Users/zhuxiaoming/Documents/trae_projects/template01/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../fast-npm-meta@1.4.2/node_modules/fast-npm-meta/dist/cli.mjs" "$@"
else
  exec node  "$basedir/../../../../../../fast-npm-meta@1.4.2/node_modules/fast-npm-meta/dist/cli.mjs" "$@"
fi
